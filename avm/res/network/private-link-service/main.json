              }
            }
          }
        ],
        "accessMode": "[parameters('accessMode')]",
        "autoApproval": "[if(not(empty(parameters('autoApprovalSubscriptionIds'))), createObject('subscriptions', parameters('autoApprovalSubscriptionIds')), null())]",
        "destinationIPAddress": "[parameters('destinationIPAddress')]",
        "enableProxyProtocol": "[parameters('enableProxyProtocol')]",
        "fqdns": "[parameters('fqdns')]",
